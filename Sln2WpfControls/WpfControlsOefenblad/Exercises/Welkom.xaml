<Page x:Class="WpfControlsOefenblad.Exercises.Welkom"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfControlsOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BasicTextBox">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" />
        <Border Background="White" Grid.Row="1">
            <!-- HIERONDER BEGINT XAML VAN DE OEFENING -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Name="lblNaam" Grid.Column="0" Grid.Row="0" Content="Naam:"/>
                <TextBox Name="txtNaam" Grid.Column="0" Grid.Row="1" Margin="5"/>
                <Button Name="btnHallo" Grid.Column="1" Grid.Row="1" Content="Zeg Hallo" Margin="5" Padding="2" Click="btnHallo_Click"/>
                <TextBlock Name="txtFout" Grid.Column="0" Grid.Row="2" Margin="10" Foreground="#900" FontStyle="Italic" Text="gelieve een naam in the vullen" Visibility="Hidden"/>
                <TextBlock Name="txtWelkom" Grid.Column="0" Grid.Row="3" Margin="10" FontSize="16" FontWeight="SemiBold" Text="..."/>
            </Grid>

        </Border>
    </Grid>
</Page>
