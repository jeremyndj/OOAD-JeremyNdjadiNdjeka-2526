<Page x:Class="WpfControlsOefenblad.Exercises.LanguageSelector"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfControlsOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LanguageSelector">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" />
        <Border Background="White" Grid.Row="1">
            <!-- HIERONDER BEGINT XAML VAN DE OEFENING -->
            <StackPanel>
                <ComboBox x:Name="cbxTaal" Width="120" Margin="5">
                    <ComboBoxItem Content="Kies een taal..." FontWeight="SemiBold" IsSelected="True"/>
                    <ComboBoxItem Content="Nederlands"/>
                    <ComboBoxItem Content="English"/>
                    <ComboBoxItem Content="Franþais"/>
                </ComboBox>
                <TextBlock Name="txtBegroeting" FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>

        </Border>
    </Grid>
</Page>
